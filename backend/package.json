{
  "name": "lavlay-api",
  "version": "1.0.0",
  "description": "LavLay Backend API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
